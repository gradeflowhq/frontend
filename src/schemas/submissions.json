            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array",
              "uniqueItems": true
            },
            {
              "items": {
                "type": [
                  "string",
                  "number",
                  "integer",
                  "null"
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "type": "object",
        "title": "Answer Map"
      }
    },
    "type": "object",
    "required": [
      "student_id",
      "answer_map"
    ],
    "title": "AdjustableSubmission"
  },
  "AdjustableQuestionResult": {
    "properties": {
      "output": {
        "title": "Output",
        "description": "Output generated from evaluating the answer",
        "type": [
          "boolean",
          "integer",
          "number"
        ]
      },
      "passed": {
        "type": "boolean",
        "title": "Passed",
        "description": "Whether the answer passed the rule check"
      },
      "feedback": {
        "type": "string",
        "title": "Feedback",
        "description": "Feedback or comments"
      },
      "rule": {
        "type": "string",
        "title": "Rule",
        "description": "ID of the rule that was applied"
      },
      "graded": {
        "type": "boolean",
        "title": "Graded",
        "description": "Whether the result has been graded",
        "default": true
      },
      "points": {
        "type": "number",
        "title": "Points",
        "description": "Points awarded for this question"
      },
      "max_points": {
        "type": "number",
        "title": "Max Points",
        "description": "Maximum points possible"
      },
      "adjusted_points": {
        "title": "Adjusted Points",
        "description": "Adjusted points for this question",
        "type": [
          "number",
          "null"
        ]
      },
      "adjusted_feedback": {
        "title": "Adjusted Feedback",
        "description": "Adjusted feedback for this question",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "type": "object",
    "required": [
      "output",
      "passed",
      "feedback",
      "rule",
      "points",
      "max_points"
    ],
    "title": "AdjustableQuestionResult"
  }
